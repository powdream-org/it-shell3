FROM zig-kcov-base

WORKDIR /workspace

# Pre-install tools from a copied mise.toml (layer cached)
COPY mise.toml .
RUN mise trust && mise install && rm mise.toml

# Activate mise so zig/deno are in PATH for all subsequent commands
RUN echo 'eval "$(mise activate bash)"' >> /root/.bashrc
ENV BASH_ENV="/root/.bashrc"
SHELL ["bash", "-c"]
