/// PoC 06: RenderState Extraction
///
/// Proves that we can:
/// 1. Create a Terminal instance headlessly (no Surface/App/PTY)
/// 2. Feed VT data into it (Terminal.print)
/// 3. Call RenderState.update() to snapshot the terminal state
/// 4. Iterate over RenderState cells and read codepoints + resolved styles
///
/// This validates the "server-side extraction" half of the it-shell3
/// RenderState protocol design.
const std = @import("std");
const vt = @import("ghostty-vt");

const Terminal = vt.Terminal;
const RenderState = vt.RenderState;
const Style = vt.Style;

const print = std.debug.print;

pub fn main() !void {
    const alloc = std.heap.page_allocator;

    // 1. Create a terminal (headless — no Surface, no PTY, no App)
    const cols: vt.size.CellCountInt = 80;
    const rows: vt.size.CellCountInt = 24;

    var term = try Terminal.init(alloc, .{
        .cols = cols,
        .rows = rows,
    });
    defer term.deinit(alloc);

    print("=== PoC 06: RenderState Extraction ===\n", .{});
    print("Terminal created: {}x{}\n\n", .{ cols, rows });

    // 2. Feed some text into the terminal
    // Simple ASCII
    const test_text = "Hello, it-shell3!";
    for (test_text) |c| {
        try term.print(c);
    }

    // Move to next line (CR + LF)
    term.carriageReturn();
    try term.linefeed();

    // Korean text (Hangul codepoints, pre-composed)
    // 한 = U+D55C, 글 = U+AE00, 테 = U+D14C, 스 = U+C2A4, 트 = U+D2B8
    const korean_cps = [_]u21{ 0xD55C, 0xAE00, ' ', 0xD14C, 0xC2A4, 0xD2B8 };
    for (korean_cps) |cp| {
        try term.print(cp);
    }

    // Move to next line
    term.carriageReturn();
    try term.linefeed();

    // SGR styled text: bold + red foreground
    try term.setAttribute(.bold);
    try term.setAttribute(.{ .direct_color_fg = .{ .r = 255, .g = 0, .b = 0 } });
    const styled_text = "Bold Red Text";
    for (styled_text) |c| {
        try term.print(c);
    }
    // Reset
    try term.setAttribute(.unset);

    print("Text written to terminal.\n\n", .{});

    // 3. Snapshot via RenderState.update()
    var render_state: RenderState = .empty;
    defer render_state.deinit(alloc);

    try render_state.update(alloc, &term);

    print("RenderState updated. dirty={s}, rows={}, cols={}\n", .{
        @tagName(render_state.dirty),
        render_state.rows,
        render_state.cols,
    });

    // 4. Iterate over RenderState cells
    const row_data = render_state.row_data.slice();
    const row_cells = row_data.items(.cells);
    const row_dirties = row_data.items(.dirty);

    var total_non_empty: usize = 0;
    var total_styled: usize = 0;
    var total_wide: usize = 0;

    print("\n--- Row-by-row extraction ---\n", .{});

    for (0..render_state.rows) |y| {
        const cells = row_cells[y].slice();
        const cells_raw = cells.items(.raw);
        const cells_style = cells.items(.style);
        const is_dirty = row_dirties[y];

        // Build row text using a fixed buffer
        var text_buf: [512]u8 = undefined;
        var text_len: usize = 0;
        var has_content = false;

        for (0..@min(cells_raw.len, render_state.cols)) |x| {
            const cell = cells_raw[x];
            const cp = cell.codepoint();

            if (cp != 0 and cp != ' ') {
                has_content = true;
                total_non_empty += 1;

                if (cell.hasStyling()) {
                    total_styled += 1;
                }

                if (cell.wide == .wide) {
                    total_wide += 1;
                }
            }

            // Encode codepoint to UTF-8 for display
            if (cp != 0 and text_len + 4 <= text_buf.len) {
                const len = std.unicode.utf8Encode(cp, text_buf[text_len..][0..4]) catch continue;
                text_len += len;
            }
        }

        if (has_content) {
            print("Row {d:2} [dirty={s}]: \"{s}\"\n", .{
                y,
                if (is_dirty) "Y" else "N",
                text_buf[0..text_len],
            });

            // Show style details for rows with styled content
            for (0..@min(cells_raw.len, render_state.cols)) |x| {
                const cell = cells_raw[x];
                const style = cells_style[x];
                const cp = cell.codepoint();

                if (cp != 0 and cp != ' ' and cell.hasStyling()) {
                    const fg_str: []const u8 = switch (style.fg_color) {
                        .none => "default",
                        .palette => "palette",
                        .rgb => "rgb",
                    };
                    print("  [{d:2}] U+{X:0>4} fg={s} bold={} wide={s}\n", .{
                        x,
                        cp,
                        fg_str,
                        style.flags.bold,
                        @tagName(cell.wide),
                    });
                }
            }
        }
    }

    // 5. Summary
    print("\n=== Extraction Summary ===\n", .{});
    print("Total non-empty cells: {}\n", .{total_non_empty});
    print("Total styled cells:    {}\n", .{total_styled});
    print("Total wide cells:      {}\n", .{total_wide});
    print("\nCursor position: ({}, {})\n", .{
        render_state.cursor.active.x,
        render_state.cursor.active.y,
    });
    print("Background color: RGB({}, {}, {})\n", .{
        render_state.colors.background.r,
        render_state.colors.background.g,
        render_state.colors.background.b,
    });

    print("\n=== PoC 06 PASSED ===\n", .{});
}
